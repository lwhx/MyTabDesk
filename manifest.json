{
  "manifest_version": 3,
  "name": "MyTabDesk",
  "version": "2.0.0",
  "description": "A local-first new tab workspace for saving and restoring browser tabs.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "action": {
    "default_title": "MyTabDesk",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
